# Environment Configuration for Poker CLI
# Copy this file to .env and fill in your actual values

# LLM Provider (openai / anthropic / deepseek / qwen / local)
POKER_PROVIDER=openai

# OpenAI-compatible API endpoint
BASE_URL=https://api.openai.com/v1

# Your API key (preferred: use POKER_{PROVIDER}_API_KEY instead)
POKER_OPENAI_API_KEY=sk-your-api-key-here
API_KEY=sk-your-api-key-here

# Model configuration
MODEL_NAME=gpt-4o-mini

# Debug mode
VERBOSE=true
